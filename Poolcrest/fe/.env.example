# ==============================================================================
# Poolcrest Frontend - Environment Variables Example
# ==============================================================================
# Copy this file to .env and update with your actual values
# 
# Note: These variables are embedded at BUILD time, not RUNTIME
# If you change these, you must rebuild the Docker image
# ==============================================================================

# API Configuration
# Development: Use /api (proxied by Vite to http://localhost:8000/api)
# Production: Use full URL to your backend API
VITE_API_BASE_URL=/api

# For production deployment with separate backend domain:
# VITE_API_BASE_URL=https://api.yourdomain.com/api
# VITE_API_BASE_URL=https://yourdomain.com/api

# WebSocket Configuration (if needed separately)
# VITE_WS_BASE_URL=ws://localhost:8000/ws
# VITE_WS_BASE_URL=wss://yourdomain.com/ws

# Application Environment
NODE_ENV=production

# Feature Flags (optional)
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG=false

# Third-party Services (optional)
# VITE_GOOGLE_ANALYTICS_ID=UA-XXXXXXXXX-X
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx

# ==============================================================================
# Notes:
# ==============================================================================
# 1. All VITE_ prefixed variables are available in your code via import.meta.env
#    Example: const apiUrl = import.meta.env.VITE_API_BASE_URL
#
# 2. These variables are replaced at BUILD time, not runtime
#    To change them, you must rebuild: docker-compose build poolcrest-fe
#
# 3. For sensitive values, NEVER commit the actual .env file to git
#
# 4. In docker-compose.yml, you can override these with build args:
#    build:
#      context: ./fe
#      dockerfile: Dockerfile
#      args:
#        VITE_API_BASE_URL: https://api.production.com/api
# ==============================================================================
