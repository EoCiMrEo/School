# ==============================================================================
# Poolcrest Backend - Docker Ignore File
# ==============================================================================
# Excludes unnecessary files from Docker build context to reduce image size
# and build time, following security best practices.
# ==============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
eggs/
.eggs/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Virtual Environments
venv/
env/
ENV/
environment/
.venv

# Django
*.log
*.pot
*.pyc
db.sqlite3
db.sqlite3-journal
/media
/staticfiles
/static

# Environment Variables (CRITICAL - Never include in Docker image)
.env
.env.*
*.env
!.env.example

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.sublime-project
*.sublime-workspace

# Git
.git/
.gitignore
.gitattributes

# Docker
Dockerfile*
docker-compose*.yml
.dockerignore

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/
coverage/
*.cover
.hypothesis/

# Logs
logs/
*.log
*Log
*logs

# Documentation
*.md
!README.md
docs/
diagrams/

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml
azure-pipelines.yml

# Temporary Files
tmp/
temp/
*.tmp
*.bak
*.swp

# Node.js (if any frontend tools are used in backend)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Supabase
supabase/

# Bug fixes and solutions (not needed in production)
bugs_problems_solutions/

# Scripts (unless needed for runtime)
scripts/
!scripts/production_*.py

# Test files
test/
tests/
*_test.py
test_*.py

# Backup files
*.backup
*.bak
*~

# MacOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# Development databases
*.sqlite
*.sqlite3
*.db

# Jupyter Notebooks
.ipynb_checkpoints

# pyenv
.python-version

# Celery
celerybeat-schedule
celerybeat.pid

# mypy
.mypy_cache/
.dmypy.json
dmypy.json

# Pyre type checker
.pyre/

# Local configuration files
local_settings.py
settings_local.py

# Security and sensitive data
*.pem
*.key
*.cert
*.crt
secrets/
credentials/
