# Poolcrest Backend Environment Variables
# Copy this file to .env and update with your actual values

# =============================================================================
# Test Environment
# =============================================================================
POOLCREST_ADMIN_EMAIL=admin@poolcrest.com
POOLCREST_ADMIN_PASSWORD=change-me

POOLCREST_MANAGER_EMAIL=manager@poolcrest.com
POOLCREST_MANAGER_PASSWORD=change-me

POOLCREST_TECH_EMAIL=technician@poolcrest.com
POOLCREST_TECH_PASSWORD=change-me

POOLCREST_CUSTOMER_EMAIL=customer@poolcrest.com
POOLCREST_CUSTOMER_PASSWORD=change-me

# =============================================================================
# Django Configuration
# =============================================================================
SECRET_KEY=replace-with-a-strong-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,poolcrest-api.com,poolcrest-fe

# =============================================================================
# Local Docker Database Configuration
# =============================================================================
DOCKER_DB_NAME=poolcrest_db
DOCKER_DB_USER=postgres
DOCKER_DB_PSWD=postgres
DOCKER_DB_HOST=localhost
DOCKER_DB_PORT=5432

# =============================================================================
# Supabase Cloud Database Configuration
# =============================================================================
# SUPABASE_DB_HOST=aws-0-us-east-1.pooler.supabase.com
# SUPABASE_DB_NAME=postgres
# SUPABASE_DB_USER=postgres.your-project-ref
# SUPABASE_DB_PASSWORD=replace-with-your-supabase-password
# SUPABASE_DB_PORT=6543

# # Alternative: Use Supabase URL (if you prefer URL over individual params)
# SUPABASE_DATABASE_URL=postgresql://postgres:replace-with-password@db.your-project-ref.supabase.co:5432/postgres

# # =============================================================================
# # Supabase API Configuration (for integration with existing frontend)
# # =============================================================================
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=replace-with-service-role-key
# SUPABASE_ANON_KEY=replace-with-anon-key

# =============================================================================
# JWT Configuration
# =============================================================================
JWT_SECRET_KEY=replace-with-a-strong-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_LIFETIME=60
JWT_REFRESH_TOKEN_LIFETIME=7

# =============================================================================
# Email Configuration
# =============================================================================
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=replace-with-smtp-username
EMAIL_HOST_PASSWORD=replace-with-smtp-password
DEFAULT_FROM_EMAIL=verified-sender@example.com
EMAIL_FAIL_SILENTLY=False
EMAIL_TIMEOUT=15

# =============================================================================
# Redis Configuration (for caching and sessions)
# =============================================================================
USE_REDIS=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Optional: Enable Celery for async tasks
USE_CELERY=false

# =============================================================================
# Third-party API Keys
# =============================================================================
# Payment Processing
STRIPE_PUBLISHABLE_KEY=pk_test_replace-with-your-publishable-key
STRIPE_SECRET_KEY=sk_test_replace-with-your-secret-key
STRIPE_WEBHOOK_SECRET=whsec_replace-with-your-webhook-secret

# SMS/Communication
TWILIO_ACCOUNT_SID=replace-with-twilio-sid
TWILIO_AUTH_TOKEN=replace-with-twilio-token
TWILIO_PHONE_NUMBER=+1234567890

# =============================================================================
# Application Configuration
# =============================================================================
APP_ENV=development
FRONTEND_URL=https://poolcrest.com
API_VERSION=v1

# File Upload Configuration
MAX_UPLOAD_SIZE=10485760
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx

# =============================================================================
# Security Configuration
# =============================================================================
CSRF_TRUSTED_ORIGINS=http://localhost:4028,https://poolcrest.com

# Session Configuration
SESSION_COOKIE_AGE=86400
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True

# =============================================================================
# Monitoring and Logging
# =============================================================================
LOG_LEVEL=INFO
SENTRY_DSN=replace-with-sentry-dsn

# =============================================================================
# Feature Flags
# =============================================================================
ENABLE_API_DOCS=True
ENABLE_DEBUG_TOOLBAR=True
ENABLE_ADMIN_PANEL=True
ENABLE_RATE_LIMITING=True

# =============================================================================
# Business Configuration
# =============================================================================
TIME_ZONE=America/New_York
LANGUAGE_CODE=en-us
COMPANY_NAME=Poolcrest LLC
COMPANY_EMAIL=info@poolcrest.com
COMPANY_PHONE=+1-555-123-POOL
