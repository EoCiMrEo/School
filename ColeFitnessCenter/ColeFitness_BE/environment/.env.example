# Local Docker database settings used by backend connection fallback
DOCKER_DB_HOST=colefitness_db
DOCKER_DB_PORT=5432
DOCKER_DB_NAME=colefitness_db
DOCKER_DB_USER=colefitness_user
DOCKER_DB_PSWD=change_this_password

# Optional cloud database URL used after local retries fail
DB_URL=postgresql+psycopg2://username:password@host:5432/database_name

# JWT settings
JWT_SECRET_KEY=change_this_to_a_long_random_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
